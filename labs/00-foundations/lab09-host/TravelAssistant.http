@Lab05Host_HostAddress = http://localhost:5000

###############################################
# OpenAI-Compatible Chat Completions API
###############################################

### Simple Chat - First Message
POST {{Lab05Host_HostAddress}}/TravelAssistant/v1/chat/completions
Content-Type: application/json

{
  "model": "gpt-4.1-mini",
  "messages": [
    {
      "role": "user",
      "content": "オーストラリアで必ず訪れるべきおすすめの場所を教えてください。"
    },
    {
      "role": "assistant",
      "content": "オーストラリアには素晴らしい旅行先がたくさんあります。特におすすめの場所は次のとおりです。\n\n1. **シドニー** - オペラハウスとハーバーブリッジで有名\n2. **グレートバリアリーフ** - 世界最大のサンゴ礁で、シュノーケリングやダイビングに最適\n3. **メルボルン** - アート、文化、カフェ文化で知られる都市\n4. **ウルル（エアーズロック）** - オーストラリア中心部にある象徴的な赤い一枚岩\n5. **ゴールドコースト** - 美しいビーチとテーマパークが魅力\n6. **タスマニア** - 壮大な自然と野生動物を楽しめる\n7. **ケアンズ** - グレートバリアリーフと熱帯雨林への玄関口\n\nどの場所もそれぞれ異なる魅力があります。どんなアクティビティに興味がありますか？"
    },
    {
      "role": "user",
      "content": "この中で子ども連れの家族におすすめなのはどこですか？"
    }
  ]
}

### Flight Search Request
POST {{Lab05Host_HostAddress}}/TravelAssistant/v1/chat/completions
Content-Type: application/json

{
  "model": "gpt-4.1-mini",
  "messages": [
    {
      "role": "user",
      "content": "来月の東京発メルボルン行きのフライトを探してください。"
    }
  ]
}

# OpenAI-Compatible Responses API

### Create a Conversation
POST {{Lab05Host_HostAddress}}/v1/conversations
Content-Type: application/json

{
  "items": [
    {
      "type": "message",
      "role": "user",
      "content": "こんにちは。オーストラリア旅行を計画しています。"
    }
  ]
}

### Response API - Stateless (without conversation)
POST {{Lab05Host_HostAddress}}/TravelAssistant/v1/responses
Content-Type: application/json

{
  "stream": false,
  "input": [
    {
      "type": "message",
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "オーストラリアで必ず訪れるべきおすすめの場所を教えてください。"
        }
      ]
    }
  ]
}

### Response API - Stateful (with conversation)
# First create a conversation using the endpoint above, then use the conversation ID here
POST {{Lab05Host_HostAddress}}/TravelAssistant/v1/responses
Content-Type: application/json

{
  "stream": false,
  "conversation": "conv_YOUR_CONVERSATION_ID_HERE",
  "input": [
    {
      "type": "message",
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "子ども連れの家族には、どの旅行先がおすすめですか？"
        }
      ]
    }
  ]
}

### Get Conversation Items
# Replace with your conversation ID from the create conversation response
GET {{Lab05Host_HostAddress}}/v1/conversations/conv_YOUR_CONVERSATION_ID_HERE/items?include=string
