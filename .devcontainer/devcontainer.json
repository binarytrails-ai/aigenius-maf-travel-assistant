// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
  "name": "AI Agent Development Environment",
  "image": "mcr.microsoft.com/devcontainers/dotnet:dev-10.0-noble",
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/powershell:2": {},
    "ghcr.io/devcontainers/features/node:2": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "extensions": "ml"
    },
    "ghcr.io/azure/azure-dev/azd:latest": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "GitHub.copilot-chat",
        "GitHub.copilot",
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.black-formatter",
        "mathematic.vscode-pdf",
        "ms-dotnettools.dotnet-interactive-vscode",
        "humao.rest-client"
      ],
      "settings": {
        "workbench.colorTheme": "Default Dark+"
      }
    }
  },
  "containerEnv": {
    "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true",
    "DOTNET_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS": "true"
  },
  "onCreateCommand": "curl -sSL https://aspire.dev/install.sh | bash",
  "postCreateCommand": "dotnet tool install -g Microsoft.dotnet-interactive && dotnet interactive jupyter install"
}